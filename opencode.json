{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "code-review-graph": {
      "type": "local",
      "command": ["code-review-graph", "serve"],
      "enabled": true
    },
    "graphify": {
      "type": "local",
      "command": ["python", "-m", "graphify.serve", "graphify-out/graph.json"],
      "enabled": true
    }
  }
}
