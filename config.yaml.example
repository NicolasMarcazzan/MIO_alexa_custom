# config.yaml — unified configuration for alexa-custom
#
# Copy this file to config.yaml and fill in your values.
# config.yaml is hot-reloaded: save the file and changes apply within ~4 seconds.

# ---------------------------------------------------------------------------
# env: — environment variables (credentials and runtime settings)
# ---------------------------------------------------------------------------
# Values are written into the process environment on startup and on every
# hot-reload. Keys and values must be strings.

env:
  # --- LiveKit (required) ---
  LIVEKIT_URL: wss://alexa-custom-u4t05e8q.livekit.cloud
  LIVEKIT_ROOM: alexa-stanza
  LIVEKIT_API_KEY: APIJ5drZtgbbAxQ
  LIVEKIT_API_SECRET:V9lrooIcGPvRWNlaezaEQY9DG1Sm7spLg3dbMeTEuF3

  # --- Audio devices ---
  # Substring of the PipeWire/ALSA device name, or a sounddevice index.
  # Omit to use system defaults.
  #INPUT_DEVICE: pipewire
  #OUTPUT_DEVICE: pipewire

  # --- WebRTC microphone processing (all default to 1 = enabled) ---
  #MIC_AGC: 1                 # Automatic Gain Control
  #MIC_AEC: 1                 # Acoustic Echo Cancellation
  #MIC_NOISE_SUPPRESSION: 1   # Noise suppression
  #MIC_HIGH_PASS_FILTER: 1    # High-pass filter (removes low-frequency rumble)

  # --- Vosk STT model ---
  # Path to the Vosk model directory. Run 'alexa-setup' to download it.
  #VOSK_MODEL_PATH: models/it

  # --- Piper TTS voices ---
  # Directory where Piper .onnx voice files are stored. Default: models/piper
  # Voices are downloaded by 'alexa-setup --piper-voice <name>'.
  #PIPER_VOICES_DIR: models/piper

  # --- Audio interaction tuning (all optional, sensible defaults applied) ---
  # Output volume for the speaker (0.0–1.0, default 0.5 = 50%).
  # This sets the PulseAudio software volume used by pw-play.
  #output_volume: 0.5
  # Time the STT gate stays held after a playback subprocess exits, to let
  # PipeWire/ALSA buffers drain and the acoustic echo decay.
  #AUDIO_POST_PLAYBACK_MS: 100
  # Silence prepended to short tones/beeps so the PortAudio stream finishes
  # cold-start before the audible part begins.
  #AUDIO_TONE_PREROLL_MS: 300
  # Idle time after which the STT capture considers the user has stopped
  # speaking (VAD endpoint). Lower = snappier replies; higher = better for
  # users who pause mid-sentence.
  #STT_VAD_SILENCE_MS: 700

  # --- Empty room timeout ---
  # Disconnect from LiveKit if the room has no other participants for this
  # many seconds. Set to 0 or omit to stay connected indefinitely.
  #EMPTY_ROOM_TIMEOUT: 30

  # --- Telegram (required for 'telegram' action type) ---
  #TELEGRAM_BOT_TOKEN: "123456789:AABBccDDeeFFggHH-your-token-here"
  #TELEGRAM_CHAT_ID: "123456789"

  # --- MQTT / Home Assistant ---
  # MQTT_HOST is required to enable MQTT. All other values have defaults.
  #MQTT_HOST: 127.0.0.1
  #MQTT_PORT: 1883
  #MQTT_TOPIC_PREFIX: alexa
  #MQTT_NODE_ID: living_room   # defaults to system hostname

  # --- Weather ---
  # Default location when no city is specified (lat/lon). Omit to use GeoIP.
  #WEATHER_LAT: 45.4384
  #WEATHER_LON: 10.9916

# ---------------------------------------------------------------------------
# web: — browser dashboard (optional)
# ---------------------------------------------------------------------------
# Start with: alexa-client --web [--web-port PORT]
# The dashboard is served at http://<host>:PORT/ — no authentication,
# bind to LAN interfaces only.

#web:
#  port: 8080    # HTTP / WebSocket port (default: 8080)

# ---------------------------------------------------------------------------
# Wake words
# ---------------------------------------------------------------------------
# Each group has a primary word, optional aliases (alternative phrases that
# map to the same group), and an optional per-group trigger list.
# If a group defines no triggers, the global top-level triggers list is used.

wake_words:
  - word: "megatron"
    aliases:
      - "ehi megatron"       # alternative recognition phrase for the same group

  - word: "jarvis"

# ---------------------------------------------------------------------------
# Recognition settings
# ---------------------------------------------------------------------------

# How long to listen for a command after the wake word (seconds, two-stage only).
command_timeout: 5.0

# Recognition mode:
#   two-stage    — low CPU; wake word detected first, then a timed window opens
#   single-stage — always-on transcription; say wake word + command in one phrase
recognition_mode: two-stage

# Vosk confidence threshold (0.0–1.0) to accept a wake word in two-stage mode.
wake_confidence: 0.90

# Tone name to play when a wake word is matched.
# Available names: wake, startup, success, error, info, warning (or 'none' to disable)
wake_tone: wake

# ---------------------------------------------------------------------------
# TTS — text-to-speech backend
# ---------------------------------------------------------------------------
# Two backends are available:
#   piper — neural TTS, natural voice. Default. ~60 MB model per voice.
#           Run 'alexa-setup --piper-voice <name>' to download a voice.
#           Available voices:
#             - it_IT-paola-medium    (female, default)
#             - it_IT-riccardo-x_low  (male, faster)
#   pico  — classic concatenative TTS (libttspico). Robotic but very low
#           latency and no model to download.
#
# If 'piper' is selected but unavailable (package or voice missing), the
# system automatically falls back to Pico with a warning in the log.

tts:
  backend: piper
  voice: it_IT-paola-medium
  # Silence prepended to TTS audio (ms). Covers PipeWire/PortAudio cold-start.
  # Lower = snappier responses; raise if you hear the first syllable clipped.
  preroll_ms: 400

# Legacy single-key form (still honoured, overridden by the tts: block above):
#tts_preroll_ms: 400
#tts_backend: piper
#tts_voice: it_IT-paola-medium

# ---------------------------------------------------------------------------
# STT — speech-to-text backend
# ---------------------------------------------------------------------------
# Three backends are available:
#   vosk        — default, grammar-constrained recognition (low CPU)
#   sherpa-onnx — streaming Zipformer transducer (higher accuracy)
#   whisper     — OpenAI Whisper tiny multilingual via sherpa-onnx (best accuracy)
#
# Model downloads:
#   alexa-setup                                    # Vosk (small Italian)
#   alexa-setup --sherpa-onnx                      # Zipformer transducer (kroko_128l)
#   alexa-setup --whisper                          # Whisper tiny multilingual INT8

stt:
  backend: vosk
  # model_path: models/it             # For vosk
  # model_path: models/it/kroko_128l  # For sherpa-onnx
  # model_path: models/whisper-tiny   # For whisper (default)

# ---------------------------------------------------------------------------
# Startup actions
# ---------------------------------------------------------------------------
# Executed once when the daemon finishes initializing.

on_startup:
  - type: say
    text: "Sistema pronto"
    lang: "it-IT"

# ---------------------------------------------------------------------------
# Global fallback triggers
# ---------------------------------------------------------------------------
# Used by any wake word group that defines no per-group triggers.
# All action types are shown below for reference.

triggers:
  # --- log: write a message to the application log ---
  - phrase: "test"
    actions:
      - type: log
        message: "command recognition working"

  # --- say: speak text via TTS ---
  - phrase: "di qualcosa"
    actions:
      - type: say
        text: "Ciao dal sistema vocale"
        lang: "it-IT"

  # --- tone: play a predefined sound ---
  # Available names: startup, success, error, info, warning
  - phrase: "suona"
    actions:
      - type: tone
        name: info

  # --- shell: run a shell command ---
  - phrase: "aggiorna"
    actions:
      - type: shell
        command: "systemctl restart my-service"

  # --- livekit_join: connect to the LiveKit room ---
  - phrase: "connettiti"
    actions:
      - type: livekit_join

  # --- chiama: ask confirmation then call via livekit_join ---
  - phrase: "chiama Stefano"
    actions:
      - type: ask
        text: "Vuoi chiamare?"
        lang: "it-IT"
        timeout: 5.0
        on_reply:
          - phrase: "si"
            actions:
              - type: say
                text: "Sto chiamando Stefano"
              - type: livekit_join
              - type: telegram
                text: "Collegati con casa <room>"
                # chat_id: "12345678"
          - phrase: "no"
            actions:
              - type: say
                text: "Chiamata annullata"
        on_else:
          - type: say
            text: "Non ho capito"

  # --- telegram: send a Telegram message ---
  - phrase: "manda messaggio"
    actions:
      - type: telegram
        text: "Messaggio vocale ricevuto"
        # chat_id: "123456789"  # overrides TELEGRAM_CHAT_ID env var
        # Use <room> placeholder to include a LiveKit browser join URL:
        # text: "Entra nella stanza: <room>"

  # --- mqtt_publish: publish an MQTT message ---
  - phrase: "accendi la luce"
    actions:
      - type: mqtt_publish
        topic: "home/light/set"
        payload: "ON"
        retain: false       # optional, default false

  # --- ask: speak a question and wait for a reply ---
  - phrase: "chiedi conferma"
    actions:
      - type: ask
        text: "Sei sicuro?"
        lang: "it-IT"
        timeout: 5.0
        on_reply:
          - phrase: "si"
            actions:
              - type: tone
                name: success
        on_else:
          - type: tone
            name: error

  # --- weather: forecast for known cities (exact match) ---
  - phrase: "che tempo fa a Verona"
    actions:
      - type: weather
        city: Verona

  - phrase: "che tempo fa a San Giovanni Lupatoto"
    actions:
      - type: weather
        city: San Giovanni Lupatoto

  - phrase: "che tempo fa a Montorio"
    actions:
      - type: weather
        city: Montorio

  # --- weather: generic with {city} variable extracted from speech ---
  # The {city} placeholder is auto-extracted from what the user says.
  - phrase: "che tempo fa a {city}"
    actions:
      - type: weather

  # --- weather: no city specified — uses default location or GeoIP ---
  - phrase: "che tempo fa"
    actions:
      - type: weather

  # --- weather: future days ---
  - phrase: "che tempo fa domani"
    actions:
      - type: weather
  - phrase: "che tempo fa dopodomani"
    actions:
      - type: weather
  - phrase: "che tempo fa tra {n} giorni"
    actions:
      - type: weather
  - phrase: "che tempo fa {day}"
    actions:
      - type: weather

  - phrase: "com'è il meteo"
    actions:
      - type: weather
  - phrase: "com'è il meteo oggi"
    actions:
      - type: weather
  - phrase: "com'è il meteo {day}"
    actions:
      - type: weather

  # --- timer: set a countdown timer ---
  # Duration is parsed from natural language: "2 minuti", "1 ora e 30 minuti", etc.
  - phrase: "metti un timer da {duration}"
    actions:
      - type: timer
  - phrase: "metti un timer di {duration}"
    actions:
      - type: timer
  - phrase: "metti un timer per {duration}"
    actions:
      - type: timer
  - phrase: "imposta un timer da {duration}"
    actions:
      - type: timer
  - phrase: "imposta un timer di {duration}"
    actions:
      - type: timer
  - phrase: "attiva un timer di {duration}"
    actions:
      - type: timer
  - phrase: "crea un timer da {duration}"
    actions:
      - type: timer
  - phrase: "avvia un timer da {duration}"
    actions:
      - type: timer
  - phrase: "fai partire un timer da {duration}"
    actions:
      - type: timer
  - phrase: "avvia un conto alla rovescia di {duration}"
    actions:
      - type: timer
  - phrase: "metti un conto alla rovescia da {duration}"
    actions:
      - type: timer

  # --- timer_cancel: stop ringing or cancel active timers ---
  - phrase: "ferma il timer"
    actions:
      - type: timer_cancel
  - phrase: "ferma tutti i timer"
    actions:
      - type: timer_cancel
  - phrase: "annulla il timer"
    actions:
      - type: timer_cancel
  - phrase: "annulla tutti i timer"
    actions:
      - type: timer_cancel
  - phrase: "stop"
    actions:
      - type: timer_cancel
  - phrase: "basta"
    actions:
      - type: timer_cancel

  # --- timer_status: check remaining time ---
  - phrase: "quanto manca"
    actions:
      - type: timer_status
  - phrase: "quanto manca al timer"
    actions:
      - type: timer_status
  - phrase: "quanto tempo rimane"
    actions:
      - type: timer_status
  - phrase: "timer"
    actions:
      - type: timer_status

  # --- date ---
  - phrase: "che giorno è"
    actions:
      - type: date
  - phrase: "che giorno è oggi"
    actions:
      - type: date

  # --- time ---
  - phrase: "che ora è"
    actions:
      - type: time
  - phrase: "che ore sono"
    actions:
      - type: time

  # --- saluti / cortesia (offline, no LLM, no internet) ---
  - phrase: "ciao"
    actions:
      - type: say
        text: "Ciao! Come posso aiutarti?"
        lang: "it-IT"
  - phrase: "salve"
    actions:
      - type: say
        text: "Salve! Piacere di sentirti."
        lang: "it-IT"
  - phrase: "buongiorno"
    actions:
      - type: say
        text: "Buongiorno!"
        lang: "it-IT"
  - phrase: "buonasera"
    actions:
      - type: say
        text: "Buonasera!"
        lang: "it-IT"
  - phrase: "grazie"
    actions:
      - type: say
        text: "Prego!"
        lang: "it-IT"
  - phrase: "grazie mille"
    actions:
      - type: say
        text: "Di niente!"
        lang: "it-IT"
  - phrase: "ok grazie"
    actions:
      - type: say
        text: "Di niente!"
        lang: "it-IT"

  # --- identità (offline, no LLM) ---
  - phrase: "chi sei"
    actions:
      - type: say
        text: "Sono il tuo assistente vocale personale."
        lang: "it-IT"
  - phrase: "presentati"
    actions:
      - type: say
        text: "Ciao, sono il tuo assistente vocale. Posso rispondere a domande, darti l'ora, il meteo, gestire timer e molto altro."
        lang: "it-IT"
  - phrase: "cosa sai fare"
    actions:
      - type: say
        text: "So darti l'ora e la data, il meteo, gestire timer, accendere luci, chiamare, mandare messaggi e rispondere a domande di cultura generale."
        lang: "it-IT"
  - phrase: "che cosa sai fare"
    actions:
      - type: say
        text: "So darti l'ora e la data, il meteo, gestire timer, accendere luci, chiamare, mandare messaggi e rispondere a domande di cultura generale."
        lang: "it-IT"

  # --- interiezioni (offline, no LLM) ---
  - phrase: "bello"
    actions:
      - type: say
        text: "Sono contento che ti piaccia!"
        lang: "it-IT"
  - phrase: "bellissimo"
    actions:
      - type: say
        text: "Sono contento che ti piaccia!"
        lang: "it-IT"
  - phrase: "che noia"
    actions:
      - type: say
        text: "Mi dispiace, cercherò di fare meglio."
        lang: "it-IT"
  - phrase: "noioso"
    actions:
      - type: say
        text: "Mi dispiace, cercherò di fare meglio."
        lang: "it-IT"
  - phrase: "c'è nessuno"
    actions:
      - type: say
        text: "Sì, sono qui!"
        lang: "it-IT"
  - phrase: "ok"
    actions:
      - type: say
        text: "Ok!"
        lang: "it-IT"
  - phrase: "va bene"
    actions:
      - type: say
        text: "Va bene!"
        lang: "it-IT"
  - phrase: "perfetto"
    actions:
      - type: say
        text: "Perfetto!"
        lang: "it-IT"
